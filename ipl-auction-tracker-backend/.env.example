PORT=5000

MYSQL_DB_NAME=
MYSQL_DB_USER=
MYSQL_DB_PASSWORD=
MYSQL_DB_HOST=
MYSQL_DB_PORT=3306

JWT_SECRET=
CLIENT_URL=https://your-frontend.vercel.app
EMAIL_VERIFICATION_REQUIRED=true

# Production recommendation: HTTPS API delivery avoids SMTP port/network issues.
EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_FROM="AuctionArena <verify@your-verified-domain.example>"
RESEND_TIMEOUT_MS=10000

# Optional Gmail SMTP diagnostics/local fallback only.
# EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=
# SMTP_PASS=
# SMTP_TIMEOUT_MS=10000
